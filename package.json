    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.1",
    "electron-winstaller": "^5.1.0",
    "electron-wix-msi": "^5.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-schedule": "^2.1.1",
    "nodemailer": "^6.9.3",
    "shelljs": "^0.8.5"
